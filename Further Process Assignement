package furtherprocessassignment;

import java.io.*;
import java.util.*;


/**
 *
 * @author KVadukoot2026
 */
public class FurtherProcessAssignment {
    
    public static void main(String[] args) {
        // TODO code application logic here
        
        
        String csvFilePath = "Contact/contact.csv";
        ArrayList<Contact> contacts = new ArrayList<>();

      

       Scanner scanner = new Scanner(System.in);

       while(true) {
           
       System.out.println("\nEnter command:");
       System.out.println("a = create new contact");
       System.out.println("e = sort by email adress");
       System.out.println("y = sort by grad year");
       System.out.println("n = sort by name");
       System.out.println("q = quit");
        
       String input = scanner.nextLine();

        if (input.equals("a")){
            System.out.print("Enter name: ");
            String name = scanner.nextLine();

            System.out.print("Enter email: ");
            String email = scanner.nextLine();

            System.out.print("Enter grad year: ");
            int year = Integer.parseInt(scanner.nextLine());

            contacts.add(new Contact(name, email, String.valueOf(year), ""));
            }
        
        else if (input.equals("e")) {
            contacts.sort(Comparator.comparing(Contact::getEmail));
            System.out.println("Sorted by email.");
        }
         else if (input.equals("y")) {
            contacts.sort(Comparator.comparing(Contact::getGradYear));
             System.out.println("Sorted by grad year.");
        }
        
         else if (input.equals("n")) {
            contacts.sort(Comparator.comparing(Contact::getName));
             System.out.println("Sorted by name.");
        }
        
         else if (input.equals("q")) {
             break;
         }
           }
       try (BufferedWriter writer = new BufferedWriter(new FileWriter(csvFilePath, true))){
           for (Contact c : contacts) {
               writer.write(c.toCSV());
               writer.newLine();
           }
           
       } catch (IOException e) {
           System.err.println("Error writing to CSV file: " + e.getMessage());
       }
       
       List<Contact> list = new ArrayList<>();
       
       try (BufferedReader br = new BufferedReader(new FileReader("Contact/contact.csv"))){
           String line;
           while ((line = br.readLine()) != null){
               String[] values = line.split(",");
               
               list.add(new Contact(values[0], values[1], values[2], values[3]));
               
           }
       } catch (IOException e){
           System.err.println("Error writing to CSV file: " + e.getMessage());
       }
       
        }
    
    static class Contact{
        private String name;
        private String email;
        private String year;
        private String user;
        
      
        public Contact(String inName, String inEmail, String inYear, String inUser){
            name = inName;
            email = inEmail;
            year = inYear;
            user = inUser;
        }
        
        public Contact(){}
        public String getName() {
            return name;
        }
        
        public String getEmail(){
            return email;
        }
        
        public String getGradYear(){
            return year;
        }
        
        public String toCSV(){
            return String.join(",",
                    name,
                    email,
                    year,
                    user
            );    
        }
    }
    

    

 


    }
