package com.mycompany.pacaltriangleassignment;

import java.util.Arrays;
import java.util.Scanner;
/**
 *
 * @author KVadukoot2026
 */
public class PacalTriangleAssignment {

    public static int[] getRow(int n) {
        
        if(n == 0) {
            return new int[]{1};
        }
       //Make an integer for previous row and current row
        int[] prevRow = getRow(n -1);
        int[] currentRow = new int[n+1];
        currentRow[0] = 1;
        currentRow[n] = 1;
        //The current row shou;d be the previous row minus 1 plus the previous row 
        for (int i=1; i < n; i++) {
            currentRow[i] = prevRow[i - 1] + prevRow[i];
        }
        return currentRow;
        
        }
    
    public static void main(String[] args) {
        //Create a scanner
        Scanner scanner = new Scanner(System.in);
        //Tell the user to enter the row that they want generated 
        System.out.print("Enter n:");
        //The variable goes back to the scanner
        int n = scanner.nextInt();
        
        int[] result = getRow(n);
        //Print out the row 
        System.out.println("Row" + n + "of Pascal's Triangle");
        System.out.println(Arrays.toString(result));
    }
        
        
        
        
    }


        
        
        

